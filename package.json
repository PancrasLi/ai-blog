{
  "name": "ai-blog",
  "version": "1.0.0",
  "description": "Modern serverless AI-powered blog with Shadcn/UI, Next.js, and Velite",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && git add out/ && git commit -m 'chore: deploy to gh-pages' && git push origin main"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "next": "latest",
    "next-themes": "latest",
    "clsx": "latest",
    "tailwind-merge": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-separator": "latest",
    "lucide-react": "latest",
    "date-fns": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "class-variance-authority": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.1",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "velite": "latest"
  }
}
