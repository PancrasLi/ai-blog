{
  "name": "ai-blog",
  "version": "1.0.0",
  "description": "Modern serverless AI-powered blog with Shadcn/UI, Next.js, and Velite",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build && next export",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "deploy": "npm run export && git add out/ && git commit -m 'chore: deploy to gh-pages' && git push origin main"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "next": "^14.2.0",
    "next-themes": "^0.2.1",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.0",
    "@radix-ui/react-slot": "^2.0.2",
    "@radix-ui/react-separator": "^1.0.3",
    "lucide-react": "^0.344.0",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "velite": "^0.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.2.0",
    "@types/rss": "^0.0.32",
    "prettier": "^3.1.0"
  }
}
