{
  "name": "ai-blog",
  "version": "1.0.0",
  "description": "Modern serverless AI-powered blog with Shadcn/UI, Next.js, and Velite",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build && next export",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "deploy": "npm run export && git add out/ && git commit -m 'chore: deploy to gh-pages' && git push origin main"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "next": "14.0.4",
    "next-themes": "0.2.1",
    "clsx": "2.0.0",
    "tailwind-merge": "2.2.0",
    "lucide-react": "0.263.1",
    "date-fns": "3.0.0"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "@types/node": "20.10.6",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.16",
    "postcss": "8.4.32",
    "tailwindcss": "3.4.1",
    "eslint": "8.56.0",
    "eslint-config-next": "14.0.4",
    "prettier": "3.1.1"
  }
}
