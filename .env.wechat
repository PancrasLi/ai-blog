# 微信公众号配置 (WeChat Official Account)
# 由于安全原因，这些凭证不应提交到 Git
# For security reasons, these credentials should NOT be committed to Git

WECHAT_APPID=wxd5ac70de16cefeef
WECHAT_APPSECRET=YOUR_APP_SECRET_HERE
WECHAT_ACCESS_TOKEN=
WECHAT_TOKEN_EXPIRES_AT=

# 微信 API 端点
WECHAT_API_ENDPOINT=https://api.weixin.qq.com/cgi-bin

# 草稿箱相关
WECHAT_DRAFT_CREATE_URL=/draft/add
